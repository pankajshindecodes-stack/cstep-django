{
    "builds": [
        {
            "src": "cstep_backend/asgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.11"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "cstep_backend/asgi.py"
        }
    ]
}